# ============================================
# ATEM RAG - Configurações de Ambiente
# ============================================

# ------------------------------------
# Banco de Dados PostgreSQL
# ------------------------------------
POSTGRES_USER=atem
POSTGRES_PASSWORD=atem_secret
POSTGRES_DB=atem_rag
DATABASE_URL=postgresql+asyncpg://atem:atem_secret@localhost:5432/atem_rag

# ------------------------------------
# Configuração do LLM
# ------------------------------------
# Modelo a ser usado (ex: gpt-4o-mini, gpt-4o, claude-3-sonnet, etc.)
LLM_MODEL=gpt-4o-mini

# API Key do provider LLM (obrigatório)
LLM_API_KEY=sk-your-api-key-here

# Base URL para API customizada (opcional - deixe vazio para OpenAI direto)
# Para LiteLLM proxy: http://localhost:4000/v1
# Para OpenAI: deixe vazio
LLM_BASE_URL=

# Configurações avançadas do LLM
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# ------------------------------------
# MCP (Model Context Protocol) - Opcional
# ------------------------------------
# Ativar servidores SAP MCP (requer Node.js configurado)
MCP_ENABLED=false
